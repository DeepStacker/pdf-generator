#!/usr/bin/env bash
# Git pre-push hook — auto-bump version, build source + binary ZIPs, create GitHub release
set -euo pipefail

REMOTE="$1"
URL="$2"

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" != "refs/heads/main" ]]; then
    continue
  fi

  echo "==> [pre-push] Main branch push detected. Auto-releasing..."

  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
  cd "$SCRIPT_DIR"

  OLD_VER=$(python3 -c "
import re
with open('pdf_generator_ui.py') as f:
    for line in f:
        if 'VERSION' in line:
            m = re.search(r'[\x27\"](.+)[\x27\"]', line)
            if m:
                print(m.group(1))
                break
")

  if [ -z "$OLD_VER" ]; then
    echo "!!> [pre-push] Could not read VERSION from pdf_generator_ui.py"
    exit 1
  fi

  echo "==> [pre-push] Current version: $OLD_VER"

  BUILD=$(git rev-list --count HEAD 2>/dev/null || echo "0")
  BASE=$(echo "$OLD_VER" | sed 's/\.[0-9]*$//')
  NEW_VER="${BASE}.${BUILD}"

  echo "==> [pre-push] Bumping to: $NEW_VER"

  sed -i '' "s/VERSION = \"$OLD_VER\"/VERSION = \"$NEW_VER\"/" pdf_generator_ui.py

  git add pdf_generator_ui.py
  git commit -m "chore: auto-bump to v$NEW_VER"
  echo "==> [pre-push] Committed v$NEW_VER"

  TAG="v${NEW_VER}"
  SRC_ZIP="Audit_Engine_${TAG}.zip"
  BIN_ZIP="Audit_Engine_${TAG}_binary.zip"

  # --- Build source distribution ---
  python3 create_distribution_zip.py

  if [ ! -f "$SRC_ZIP" ]; then
    echo "!!> [pre-push] Failed to create $SRC_ZIP"
    exit 1
  fi
  echo "==> [pre-push] Source ZIP built: $SRC_ZIP"

  # --- Build compiled binary distribution ---
  echo "==> [pre-push] Building compiled binary (PyInstaller)..."
  rm -rf dist build
  BUILD_VENV=$(mktemp -d)
  python3 -m venv "$BUILD_VENV"
  source "$BUILD_VENV/bin/activate"
  pip install --quiet pyinstaller openpyxl pandas reportlab 2>/dev/null
  if python -m PyInstaller --noconfirm --clean pdf_generator.spec 2>/dev/null; then
    if [ -d "dist" ]; then
      (cd dist && zip -r "../$BIN_ZIP" .)
      echo "==> [pre-push] Binary ZIP built: $BIN_ZIP"
    fi
  else
    echo "!!> [pre-push] PyInstaller build failed — continuing with source-only release"
  fi
  deactivate 2>/dev/null || true
  rm -rf "$BUILD_VENV"

  # --- Create tag and push it ---
  git tag "$TAG"
  echo "==> [pre-push] Created local tag $TAG"
  git push origin "$TAG"

  # --- Create GitHub release with both assets ---
  echo "==> [pre-push] Creating GitHub release ..."
  RELEASE_NOTES="## Audit Engine ${NEW_VER}

Auto-generated release.

- Commit: $(git rev-parse --short HEAD)
- \`${SRC_ZIP}\` — Source distribution (requires Python)
- \`${BIN_ZIP}\` — Compiled binary (no Python needed)"

  if [ -f "$BIN_ZIP" ]; then
    gh release create "$TAG" --title "$TAG" --notes "$RELEASE_NOTES" "$SRC_ZIP" "$BIN_ZIP"
  else
    gh release create "$TAG" --title "$TAG" --notes "$RELEASE_NOTES" "$SRC_ZIP"
  fi

  # --- Clean up ---
  rm -f "$SRC_ZIP" "$BIN_ZIP"
  rm -rf dist build *.spec 2>/dev/null || true

  echo "==> [pre-push] Release $TAG published."
  echo "==> [pre-push] Push proceeding with version bump commit and tag."

  break
done

exit 0
