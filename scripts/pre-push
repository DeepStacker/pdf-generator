#!/usr/bin/env bash
# Git pre-push hook — auto-bump version, build source ZIP, create GitHub release.
# Platform binaries are built by GH Actions triggered by the tag push.
set -euo pipefail

REMOTE="$1"
URL="$2"

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" != "refs/heads/main" ]]; then
    continue
  fi

  echo "==> [pre-push] Running lint checks..."
  ruff check src/ tests/ || { echo "!!> Lint failed. Aborting push."; exit 1; }

  echo "==> [pre-push] Main branch push detected. Auto-releasing..."

  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
  cd "$SCRIPT_DIR"

  OLD_VER=$(python3 -c "
import re
with open('src/audit_engine/_version.py') as f:
    content = f.read()
    m = re.search(r'__version__ = [\\'\\\"]([^\\'\\\"]+)[\\'\\\"]', content)
    if m:
        print(m.group(1))
")

  if [ -z "$OLD_VER" ]; then
    echo "!!> [pre-push] Could not read VERSION from src/audit_engine/_version.py"
    exit 1
  fi

  echo "==> [pre-push] Current version: $OLD_VER"

  BUILD=$(git rev-list --count HEAD 2>/dev/null || echo "0")
  BASE=$(echo "$OLD_VER" | sed 's/\.[0-9]*$//')
  NEW_VER="${BASE}.${BUILD}"

  echo "==> [pre-push] Bumping to: $NEW_VER"

  sed -i '' "s/__version__ = \"$OLD_VER\"/__version__ = \"$NEW_VER\"/" src/audit_engine/_version.py

  git add src/audit_engine/_version.py
  git commit -m "chore: auto-bump to v$NEW_VER"
  echo "==> [pre-push] Committed v$NEW_VER"

  TAG="v${NEW_VER}"
  SRC_ZIP="Audit_Engine_${TAG}.zip"

  # --- Build source distribution ---
  python3 scripts/create_distribution_zip.py
  if [ ! -f "$SRC_ZIP" ]; then
    echo "!!> [pre-push] Failed to create $SRC_ZIP"
    exit 1
  fi
  echo "==> [pre-push] Source ZIP built: $SRC_ZIP"

  # --- Create tag and push it (triggers GH Actions for all platform binaries) ---
  git tag "$TAG"
  git push origin "$TAG"
  echo "==> [pre-push] Pushed tag $TAG"

  # --- Create GitHub release with source ZIP ---
  echo "==> [pre-push] Creating GitHub release..."
  RELEASE_NOTES="## Audit Engine ${NEW_VER}

Auto-generated release.

- Commit: $(git rev-parse --short HEAD)
- \`${SRC_ZIP}\` — Source distribution (requires Python)
- \`*_binary_macos.zip\` — Pre-compiled binary for macOS (built by CI)
- \`*_binary_windows.zip\` — Pre-compiled binary for Windows (built by CI)
- \`*_binary_linux.zip\` — Pre-compiled binary for Linux (built by CI)"

  gh release create "$TAG" --title "$TAG" --notes "$RELEASE_NOTES" "$SRC_ZIP" 2>/dev/null || {
    echo "==> [pre-push] Release $TAG already exists, uploading source ZIP to it..."
    gh release upload "$TAG" "$SRC_ZIP" --clobber
  }

  # --- Clean up ---
  rm -f "$SRC_ZIP"

  echo "==> [pre-push] Release $TAG published (source ZIP)."
  echo "     macOS, Windows & Linux binaries arriving via GH Actions."
  echo "==> [pre-push] Push proceeding with version bump commit."

  break
done

exit 0
