#!/usr/bin/env bash
# Git pre-push hook — auto-bump version, build ZIP, create GitHub release
# Installed by: scripts/install-hooks.sh
set -euo pipefail

REMOTE="$1"
URL="$2"

# Read refs from stdin (one line per pushed ref)
while read local_ref local_sha remote_ref remote_sha; do
  # Only act on pushes to main
  if [[ "$remote_ref" != "refs/heads/main" ]]; then
    continue
  fi

  echo "==> [pre-push] Main branch push detected. Auto-releasing..."

  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
  cd "$SCRIPT_DIR"

  # --- Read current version ---
  OLD_VER=$(python3 -c "
import re
with open('pdf_generator_ui.py') as f:
    for line in f:
        if 'VERSION' in line:
            m = re.search(r'[\x27\"](.+)[\x27\"]', line)
            if m:
                print(m.group(1))
                break
")

  if [ -z "$OLD_VER" ]; then
    echo "!!> [pre-push] Could not read VERSION from pdf_generator_ui.py"
    exit 1
  fi

  echo "==> [pre-push] Current version: $OLD_VER"

  # --- Compute next version ---
  # Count total commits to use as build number
  BUILD=$(git rev-list --count HEAD 2>/dev/null || echo "0")
  # Parse major.minor from current version, append build
  BASE=$(echo "$OLD_VER" | sed 's/\.[0-9]*$//')
  NEW_VER="${BASE}.${BUILD}"

  echo "==> [pre-push] Bumping to: $NEW_VER"

  # --- Update VERSION in file ---
  sed -i '' "s/VERSION = \"$OLD_VER\"/VERSION = \"$NEW_VER\"/" pdf_generator_ui.py

  # --- Commit version bump ---
  git add pdf_generator_ui.py
  git commit -m "chore: auto-bump to v$NEW_VER"
  echo "==> [pre-push] Committed v$NEW_VER"

  TAG="v${NEW_VER}"
  ZIP="Audit_Engine_${TAG}.zip"

  # --- Build distribution ZIP ---
  python3 create_distribution_zip.py

  if [ ! -f "$ZIP" ]; then
    echo "!!> [pre-push] Failed to create $ZIP"
    exit 1
  fi

  # --- Create and push tag ---
  echo "==> [pre-push] Creating tag $TAG ..."
  git tag "$TAG"

  # --- Create GitHub release ---
  echo "==> [pre-push] Creating GitHub release ..."
  gh release create "$TAG" \
    --title "$TAG" \
    --notes "## Audit Engine ${NEW_VER}

Auto-generated release.

- Commit: $(git rev-parse --short HEAD)
- ZIP: \`${ZIP}\`" \
    "$ZIP"

  # --- Clean up local ZIP ---
  rm -f "$ZIP"

  echo "==> [pre-push] Release $TAG published."
  echo "==> [pre-push] Push proceeding with version bump commit and tag."

  break  # Only process the first matching ref
done

exit 0
